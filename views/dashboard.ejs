<%- include('partials/head') %>
<%- include('partials/sidebar') %>

<div class="main-content">
    <%- include('partials/navbar') %>

    <div class="container">
        <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
            <div class="alert alert-success"><%= success[0] %></div>
        <% } %>
        <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
            <div class="alert alert-danger"><%= error[0] %></div>
        <% } %>

        <% if (user.rol === 'admin' || user.rol === 'tecnico') { %>

        <%# ===== MODO HISTORIAL: Banner indicador ===== %>
        <% if (typeof modoHistorial !== 'undefined' && modoHistorial) { %>
        <div class="historial-banner">
            <div class="historial-info">
                <i class="fas fa-history"></i>
                <span>Viendo historial: <strong><%= tituloFecha %></strong></span>
            </div>
            <a href="/dashboard" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-arrow-left"></i> Volver
            </a>
        </div>
        <% } %>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number"><%= stats && stats.totalTickets || 0 %></div>
                <div class="stat-label"><%= (typeof modoHistorial !== 'undefined' && modoHistorial) ? 'Tickets en período' : 'Total Tickets' %></div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats && stats.porEstado && stats.porEstado.PENDIENTE || 0 %></div>
                <div class="stat-label">Pendientes</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats && stats.porEstado && stats.porEstado.EN_PROCESO || 0 %></div>
                <div class="stat-label">En Proceso</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= (stats && stats.porEstado && stats.porEstado.SOLUCIONADO || 0) + (stats && stats.porEstado && stats.porEstado.CERRADO || 0) %></div>
                <div class="stat-label">Resueltos</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats && stats.ticketsMes || 0 %></div>
                <div class="stat-label"><%= (typeof modoHistorial !== 'undefined' && modoHistorial) ? 'En período' : 'Este Mes' %></div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span>
                    <% if (typeof modoHistorial !== 'undefined' && modoHistorial) { %>
                        Tickets - <%= tituloFecha %>
                    <% } else { %>
                        Tickets Recientes
                    <% } %>
                </span>
                <div class="card-header-actions">
                    <%# ===== BOTÓN HISTORIAL (solo si NO estamos en modo historial) ===== %>
                    <% if (typeof modoHistorial === 'undefined' || !modoHistorial) { %>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-historial" onclick="abrirModalHistorial()">
                        <i class="fas fa-calendar-alt"></i> Historial
                    </button>
                    <% } %>
                    <a href="/tickets/nuevo" class="btn btn-success btn-sm">Nuevo Ticket</a>
                </div>
            </div>
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>N° Ticket</th><th>Título</th><th>Solicitante</th>
                            <th>Área</th><th>Categoría</th><th>Prioridad</th>
                            <th>Estado</th><th>Asignación</th><th>Fecha</th><th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof tickets !== 'undefined' && tickets && tickets.length > 0) { %>
                        <% tickets.forEach(ticket => { %>
                        <tr>
                            <td><strong><%= ticket.numeroTicket %></strong></td>
                            <td><%= ticket.titulo && ticket.titulo.length > 40 ? ticket.titulo.substring(0,40)+'...' : ticket.titulo %></td>
                            <td><%= ticket.usuario && ticket.usuario.nombre || 'N/A' %></td>
                            <td><%= ticket.usuario && ticket.usuario.area || 'N/A' %></td>
                            <td><%= ticket.categoria && ticket.categoria.nombre || '—' %></td>
                            <td><span class="badge <%= helpers.getPrioridadClass(ticket.prioridad) %>"><%= ticket.prioridad %></span></td>
                            <td><span class="badge <%= helpers.getEstadoClass(ticket.estado) %>"><%= helpers.textoEstado(ticket.estado) %></span></td>
                            <td><%= ticket.tecnico && ticket.tecnico.nombre || '—' %></td>
                            <td><%= helpers.formatearFecha(ticket.fechaCreacion) %></td>
                            <td><a href="/tickets/<%= ticket.id %>" class="btn btn-primary btn-sm">Ver</a></td>
                        </tr>
                        <% }) %>
                        <% } else { %>
                        <tr><td colspan="10" style="text-align:center;padding:20px">
                            <%= (typeof modoHistorial !== 'undefined' && modoHistorial) ? 'No hay tickets en este período' : 'No hay tickets registrados este mes' %>
                        </td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <% } else { %>
        <%# ===== VISTA DE USUARIO NORMAL (sin cambios) ===== %>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
            <h1>Mis Solicitudes</h1>
            <a href="/tickets/nuevo" class="btn btn-success">Crear Nueva Solicitud</a>
        </div>
        <div class="card">
            <div class="card-header">Historial de Tickets</div>
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>N° Ticket</th><th>Título</th><th>Categoría</th>
                            <th>Prioridad</th><th>Estado</th><th>Fecha</th><th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof tickets !== 'undefined' && tickets && tickets.length > 0) { %>
                        <% tickets.forEach(ticket => { %>
                        <tr>
                            <td><strong><%= ticket.numeroTicket %></strong></td>
                            <td><%= ticket.titulo && ticket.titulo.length > 50 ? ticket.titulo.substring(0,50)+'...' : ticket.titulo %></td>
                            <td><%= ticket.categoria && ticket.categoria.nombre || '—' %></td>
                            <td><span class="badge <%= helpers.getPrioridadClass(ticket.prioridad) %>"><%= ticket.prioridad %></span></td>
                            <td><span class="badge <%= helpers.getEstadoClass(ticket.estado) %>"><%= helpers.textoEstado(ticket.estado) %></span></td>
                            <td><%= helpers.formatearFecha(ticket.fechaCreacion) %></td>
                            <td><a href="/tickets/<%= ticket.id %>" class="btn btn-primary btn-sm">Ver</a></td>
                        </tr>
                        <% }) %>
                        <% } else { %>
                        <tr><td colspan="7" style="text-align:center;padding:20px">No tienes tickets registrados</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>
    </div>

    
    <%- include('partials/footer') %>
    

    <%# ===== MODAL DE HISTORIAL - FUERA DEL FLUJO NORMAL ===== %>
<div id="modal-historial" class="modal-historial">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-calendar-alt"></i> Consultar Historial</h3>
            <button type="button" class="btn-close" onclick="cerrarModalHistorial()">&times;</button>
        </div>
        <div class="modal-body">
            <div class="filtro-mes">
                <label for="select-mes">Seleccionar mes:</label>
                <input type="month" id="select-mes" class="form-control">
            </div>
            <div class="filtro-dia">
                <label for="select-dia">Filtrar por día específico (opcional):</label>
                <input type="date" id="select-dia" class="form-control">
                <small class="text-muted">Dejar vacío para ver todo el mes</small>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="cerrarModalHistorial()">Cancelar</button>
            <button type="button" class="btn btn-primary" onclick="consultarHistorial()">
                <i class="fas fa-search"></i> Consultar
            </button>
        </div>
    </div>
</div>

</div>


<script src="/js/dashboard.js?v=2" defer></script>