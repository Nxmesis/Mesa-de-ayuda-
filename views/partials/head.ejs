<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Mesa de Ayuda' %></title>

    <!-- Fuentes y estilos base -->
    <link rel="stylesheet" href="/css/fonts.css">
    <link rel="stylesheet" href="/css/font-awesome.min.css">
    <link rel="stylesheet" href="/css/main.css">

    <!-- Estilos condicionales -->
    <% if (typeof title !== 'undefined' && title === 'Gestion de Usuarios') { %>
    <link rel="stylesheet" href="/css/usuarios.css">
    <% } %>
    <% if (typeof title !== 'undefined' && title === 'Inventario de Equipos') { %>
    <link rel="stylesheet" href="/css/inventario.css">
    <% } %>

    <!-- Chart.js solo en estadísticas -->
    <% if (typeof title !== 'undefined' && title === 'Estadísticas') { %>
    <script src="/js/chart.umd.min.js"></script>
    <% } %>

    <!-- Scripts base -->
    <script src="/js/main.js" defer></script>
    <script src="/js/notificaciones.js" defer></script>
    <script src="/js/charts.js" defer></script>
    
    <!-- Script del dashboard -->
    <% if (typeof title !== 'undefined' && (title === 'Dashboard' || title.startsWith('Historial'))) { %>
    <script src="/js/dashboard.js" defer></script>
    <% } %>
    
    <% if (typeof title !== 'undefined' && title === 'Inventario de Equipos') { %>
    <script src="/js/inventario.js" defer></script>
    <% } %>
</head>
<body>